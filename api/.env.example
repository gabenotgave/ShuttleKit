# --- MCP SSE (api/mcp_server.py → shuttlekit/mcp_server.py) — run: python mcp_server.py ---
# Default 8001 so FastAPI (uvicorn main:app) can stay on 8000.
MCP_PORT=8001
MCP_SSE_URL=http://127.0.0.1:8001/sse

# --- LangChain chat agent (api/shuttlekit/agent/, POST /api/chat) ---
# init_chat_model: set MODEL_NAME + PROVIDER for one stack; keys below are read by each SDK.
# Examples: PROVIDER=openai MODEL_NAME=gpt-4o-mini
#           PROVIDER=anthropic MODEL_NAME=claude-sonnet-4-20250514
#           PROVIDER=google_genai MODEL_NAME=gemini-2.0-flash
MODEL_NAME=
PROVIDER=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
COHERE_API_KEY=
GROQ_API_KEY=

# Optional: Azure OpenAI (when using azure_openai provider)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=

# --- Schedule ingestion (api/ingestion/ingest.py → writes ../config.json) ---
# LiteLLM model id (vision / PDF-capable). Examples:
#   gemini/gemini-1.5-flash
#   openai/gpt-4o
#   anthropic/claude-3-5-sonnet-20241022
# PDF+image support depends on the provider; Gemini is the default path.
INGESTION_MODEL=

# API key for that model’s provider (ingest.py maps this to GEMINI_/OPENAI_/ANTHROPIC_* as needed).
# Legacy: MODEL= is still read if INGESTION_MODEL is unset.
INGESTION_API_KEY=
