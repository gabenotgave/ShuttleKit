{
  "info": {
    "name": "ShuttleKit",
    "_postman_id": "shuttlekit-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Config",
      "item": [
        {
          "name": "Get campus config",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8000/api/config",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "config"]
            }
          }
        }
      ]
    },
    {
      "name": "Stops",
      "item": [
        {
          "name": "Get all stops",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8000/api/stops",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "stops"]
            }
          }
        }
      ]
    },
    {
      "name": "Routes",
      "item": [
        {
          "name": "Get all routes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8000/api/routes",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "routes"]
            }
          }
        }
      ]
    },
    {
      "name": "Schedule",
      "item": [
